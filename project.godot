; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Wind of the Woof Forest"
run/main_scene="res://src/levels/starting_forest.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

InventoryManager="*res://src/core/autoload/InventoryManager.gd"
UIManager="*res://src/core/autoload/UIManager.gd"
BuildManager="*res://src/core/autoload/BuildManager.gd"
GameManager="*res://src/core/autoload/GameManager.gd"
SaveManager="*res://src/core/autoload/SaveManager.gd"
ExplorationManager="*res://src/core/autoload/ExplorationManager.gd"
SoundManager="*res://src/core/autoload/SoundManager.gd"

[display]

window/size/viewport_width=720
window/size/viewport_height=1280
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation=1

[physics]

3d/physics_engine="Jolt Physics"
2d/default_gravity=0.0

[rendering]

textures/canvas_textures/default_texture_filter=0
rendering_device/driver.windows="d3d12"
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
2d/snap/snap_2d_transforms_to_pixel=true
2d/snap/snap_2d_vertices_to_pixel=true
